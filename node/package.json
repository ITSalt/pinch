{
  "name": "pinch",
  "version": "0.0.0",
  "description": "Architecturally-capped pacing for parallel claude -p calls. Automate yourself, not around Anthropic.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test --ext .ts",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "claude",
    "anthropic",
    "cli",
    "pacing",
    "rate-limit",
    "automation",
    "ethical"
  ],
  "author": "ITSalt",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ITSalt/pinch.git",
    "directory": "node"
  },
  "homepage": "https://github.com/ITSalt/pinch#readme",
  "bugs": {
    "url": "https://github.com/ITSalt/pinch/issues"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
